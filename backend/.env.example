NODE_ENV=development
APP_NAME=LOMS API
APP_PORT=3000
API_PREFIX=api
API_VERSION=1

CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=loms
DB_PASSWORD=loms_password
DB_DATABASE=loms
DB_LOGGING=false

SWAGGER_PATH=docs

# ── Authentication ──────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_to_a_strong_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_strong_secret_at_least_32_chars_long
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_NAME=rt
